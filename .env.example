# IntelliOS Frontend (Vite)
VITE_API_URL=/api
VITE_WS_URL=ws://localhost:5000/ws

# IntelliOS AI Core Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Groq API — required for real AI inference
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# MongoDB — optional; server runs in ephemeral mode without it
MONGODB_URI=mongodb://127.0.0.1:27017/intellios

SESSION_SECRET=change-me-in-production
LOG_LEVEL=info
ENABLE_MEMORY=false

# Legacy (frontend model selector maps to Groq models on server)
GEMINI_API_KEY=
